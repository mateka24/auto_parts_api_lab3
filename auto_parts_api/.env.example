# PostgreSQL настройки
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=auto_parts_db

# Для Docker: используйте 'postgres' (имя сервиса)
# Для локального запуска: используйте 'localhost'
DB_HOST=postgres
DB_PORT=5432

# Порт приложения
APP_PORT=4200

# JWT настройки
JWT_ACCESS_SECRET=super_secret_access_key_change_in_prod
JWT_REFRESH_SECRET=super_secret_refresh_key_change_in_prod
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Yandex OAuth настройки
YANDEX_CLIENT_ID=your_client_id
YANDEX_CLIENT_SECRET=your_client_secret
YANDEX_CALLBACK_URL=http://localhost:4200/auth/yandex/callback
